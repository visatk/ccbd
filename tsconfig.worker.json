{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    
    /* Cloudflare Edge Types */
    "types": ["./worker-configuration.d.ts"],
    "lib": ["ES2023"],
    
    /* Hono JSX (Optional Edge SSR) */
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    
    /* Strict Type-Checking */
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitAny": true,
    
    /* Resolution & Aliases */
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/server.ts", "src/db/**/*.ts", "src/api/**/*.ts"]
}
